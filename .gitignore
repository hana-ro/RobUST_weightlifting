# Ignore Unity-specific folders inside 'Unity RobUST Controller'
/Unity RobUST Controller/[Ll]ibrary/
/Unity RobUST Controller/[Tt]emp/
/Unity RobUST Controller/[Oo]bj/
/Unity RobUST Controller/[Bb]uild/
/Unity RobUST Controller/[Bb]uilds/
/Unity RobUST Controller/[Ll]ogs/
/Unity RobUST Controller/[Uu]ser[Ss]ettings/
/Unity RobUST Controller/*.log
/Unity RobUST Controller OLD/
/Unity RobUST Controller/[Ee]xperiment[Ll]ogs/

# By default, Unity supports Blender asset imports, *.blend1 blender files do not need to be committed to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/Unity RobUST Controller/[Mm]emoryCaptures/

# Recordings can get excessive in size
/Unity RobUST Controller/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/Unity RobUST Controller/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/
.vscode/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/Unity RobUST Controller/ExportedObj/
/Unity RobUST Controller/.consulo/
/Unity RobUST Controller/*.csproj
/Unity RobUST Controller/*.unityproj
/Unity RobUST Controller/*.sln
/Unity RobUST Controller/*.suo
/Unity RobUST Controller/*.tmp
/Unity RobUST Controller/*.user
/Unity RobUST Controller/*.userprefs
/Unity RobUST Controller/*.pidb
/Unity RobUST Controller/*.booproj
/Unity RobUST Controller/*.svd
/Unity RobUST Controller/*.pdb
/Unity RobUST Controller/*.mdb
/Unity RobUST Controller/*.opendb
/Unity RobUST Controller/*.VC.db

# Unity3D generated meta files
/Unity RobUST Controller/*.pidb.meta
/Unity RobUST Controller/*.pdb.meta
/Unity RobUST Controller/*.mdb.meta

# Unity3D generated file on crash reports
/Unity RobUST Controller/sysinfo.txt

# Mono auto-generated files
/Unity RobUST Controller/mono_crash.*

# Builds
/Unity RobUST Controller/*.apk
/Unity RobUST Controller/*.aab
/Unity RobUST Controller/*.unitypackage
/Unity RobUST Controller/*.unitypackage.meta
/Unity RobUST Controller/*.app

# Crashlytics generated file
/Unity RobUST Controller/crashlytics-build.properties

# TestRunner generated files
/Unity RobUST Controller/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/Unity RobUST Controller/ServerData
/Unity RobUST Controller/[Aa]ssets/StreamingAssets/aa*
/Unity RobUST Controller/[Aa]ssets/AddressableAssetsData/link.xml*
/Unity RobUST Controller/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
/Unity RobUST Controller/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/Unity RobUST Controller/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Unity RobUST Controller/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Unity RobUST Controller/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Unity RobUST Controller/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/Unity RobUST Controller/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
